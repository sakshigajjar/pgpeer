# Server
PORT=5000
NODE_ENV=development

# PostgreSQL (Supabase) — paste your connection string from the Supabase dashboard
# Format: postgresql://postgres.[REF]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL=

# Auth — JWT signing & cookie behaviour
# Generate JWT_SECRET with:  node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7
COOKIE_SECURE=false

# express-session secret — used ONLY for OAuth state CSRF protection (not user auth)
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Google OAuth (from Google Cloud Console → Credentials → OAuth Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
# Where the OAuth callback redirects the browser after login completes.
# In dev: a local URL we can open to verify cookies were set (e.g. /api/auth/me).
# In prod: the React app's URL.
FRONTEND_URL=http://localhost:5000/api/auth/me
